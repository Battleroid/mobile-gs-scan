<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ARCore is required (not optional). The app refuses to launch
         on devices without it rather than degrading silently. -->
    <uses-feature android:name="android.hardware.camera.ar" android:required="true" />

    <!-- Package visibility for Google Play Services for AR.

         Android 11+ (targetSdk >= 30) restricts which other
         packages an app can see / IPC with by default — you
         have to declare each one in <queries>. ArCoreApk's
         availability check + install flow both bind to the
         com.google.ar.core service; without this declaration,
         checkAvailability() returns UNKNOWN_ERROR (the IPC just
         silently fails) even on devices where Play Services for
         AR is installed and up to date. Required for Android 11+
         and only gets stricter on 15 / 16. -->
    <queries>
        <package android:name="com.google.ar.core" />
    </queries>

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.MobileGsScan">

        <!-- Tells Play that this app needs ARCore. MUST live inside
             <application> per ARCore docs — at the manifest root
             (where it was previously) it's silently ignored, and
             Play's auto-install of Google Play Services for AR
             on first launch never gets triggered. -->
        <meta-data android:name="com.google.ar.core" android:value="required" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".CaptureActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MobileGsScan.Capture" />

        <activity
            android:name=".ServerConfigActivity"
            android:exported="false" />

        <activity
            android:name=".CaptureDetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".DraftDetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".JobDetailActivity"
            android:exported="false"
            android:parentActivityName=".CaptureDetailActivity" />
    </application>
</manifest>
