<?xml version="1.0" encoding="utf-8"?>
<!-- Trust user-installed CAs (mkcert) in debug builds, and the
     studio's mkcert root in release. Users still have to install the
     CA on the device first via the studio's HTTP rootCA endpoint. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
