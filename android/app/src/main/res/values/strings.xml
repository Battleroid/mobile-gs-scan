<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">gs-scan</string>
    <string name="action_settings">Settings</string>
    <string name="action_save">Save</string>
    <string name="action_start_capture">Start capture</string>
    <string name="action_finish">Finish</string>
    <string name="action_new_capture">+ new capture</string>
    <string name="action_open_play_store">Open Play Store</string>
    <string name="action_cancel">Cancel</string>
    <string name="action_back">Back</string>
    <string name="action_open_viewer_web">Open viewer in browser</string>

    <!-- Settings: studio URL field. Hint reflects the auto-prefix
         behaviour in ServerConfig.normalize — bare hostname or IP
         is fine; we prepend https:// on save. -->
    <string name="hint_studio_url">192.168.1.42 or studio.local</string>
    <string name="hint_studio_url_help">scheme optional — we\'ll prepend https:// for you. type http:// explicitly if your studio runs without TLS.</string>
    <string name="label_studio_url">Studio URL</string>

    <!-- Settings: capture-rate + jpeg-quality sliders. -->
    <string name="label_capture_fps">Capture rate</string>
    <string name="hint_capture_fps">frames per second sent to the studio. higher = smoother coverage but more bandwidth and battery drain. 10 fps is the default.</string>
    <string name="capture_fps_fmt">%1$d fps</string>
    <string name="label_capture_jpeg_quality">JPEG quality</string>
    <string name="hint_capture_jpeg_quality">image quality of streamed frames. higher = sharper input for splatting but more bandwidth per frame. 85%% is the default.</string>
    <string name="capture_jpeg_quality_fmt">%1$d%%</string>

    <!-- home screen status indicator -->
    <string name="status_online">studio: online</string>
    <string name="status_offline">studio: offline</string>
    <string name="status_no_url">studio not configured</string>
    <string name="status_resolving">resolving session…</string>
    <string name="status_idle">tap a QR code from the studio to start</string>

    <!-- home screen empty states -->
    <string name="empty_no_url">tap settings and enter your studio URL to get started</string>
    <string name="empty_no_captures">no captures yet — tap \"new capture\" to start</string>

    <!-- Capture screen overlay copy. Frame-counter starts at
         capture_idle and flips to live counts ("42 frames") once
         the user taps Start. The hint sits in the centre of the
         preview to nudge them toward the Start button. -->
    <string name="capture_idle">idle — tap Start</string>
    <string name="hint_start_capture">aim the camera at your subject\nthen tap Start when ready</string>

    <!-- Capture screen coverage HUD. Top-centre overlay updated
         from CoverageRenderer.coverageStats(). Format string takes
         (well-covered-percent, total-points). -->
    <string name="coverage_initial">0%% covered</string>
    <string name="coverage_status_fmt">%1$d%% covered · %2$d points</string>

    <!-- Native capture-detail / job-detail screens. Replaces the
         old AlertDialog from MainActivity and the
         openProgressInBrowser hand-off from CaptureActivity. -->
    <string name="detail_loading">loading…</string>
    <string name="detail_status_label">status:</string>
    <string name="detail_source_label">source:</string>
    <string name="detail_frames_label">frames:</string>
    <string name="detail_created_label">created:</string>
    <string name="detail_error_label">error:</string>
    <string name="detail_result_label">result:</string>
    <string name="detail_claimed_by_label">claimed by:</string>
    <string name="detail_started_label">started:</string>
    <string name="detail_completed_label">completed:</string>
    <string name="detail_jobs_header">PIPELINE JOBS</string>
    <string name="detail_no_scene">capture not finalized yet — pipeline jobs will appear here once the capture is submitted for processing</string>
    <string name="detail_unclaimed">(unclaimed)</string>
    <string name="detail_frames_fmt">%1$d</string>
    <string name="detail_frames_with_drops_fmt">%1$d (%2$d dropped)</string>
    <string name="detail_progress_pct_fmt">%1$d%%</string>

    <!-- Job-detail subprocess log section. Mirrors the web's
         JobLogPanel: live tail polled every 3s while open + running,
         user can hide / re-open at any time. "unavailable" message
         fires for the mesh job (which has no subprocess in PR #1
         stub) and for any kind whose log file hasn\'t appeared yet. -->
    <string name="detail_log_show">show log</string>
    <string name="detail_log_hide">hide log</string>
    <string name="detail_log_unavailable">no log available for this step</string>
    <string name="detail_log_empty">(log file is empty)</string>
    <string name="detail_log_fetch_failed_fmt">could not load log: %1$s</string>

    <!-- ARCore unsupported-device dialog. Triggered when
         ArCoreApk.checkAvailability returns
         UNSUPPORTED_DEVICE_NOT_CAPABLE — almost always because
         the user\'s Google Play Services for AR is too old to
         know about their phone (the device-support list lives
         in that APK, not in our SDK pin). -->
    <string name="arcore_unsupported_title">ARCore reports unsupported</string>
    <string name="arcore_unsupported_body">Your phone hardware should support ARCore, but the system component that gates it (\"Google Play Services for AR\") is reporting otherwise. This usually means it\'s missing or out of date — its bundled device list is what tells ARCore which phones are capable, and a copy from before your phone\'s launch won\'t recognize it.\n\nTap \"Open Play Store\" to install or update Google Play Services for AR, then come back to this screen and try again.</string>
</resources>
