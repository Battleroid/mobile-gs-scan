<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Top bar: status dot + URL + settings gear. The status dot is
         driven by /api/health polling; URL comes from
         ServerConfig.studioUrl. -->
    <LinearLayout
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/statusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/dot_offline" />

        <LinearLayout
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/statusText"
                android:text="@string/status_no_url"
                android:textColor="@color/fg"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/statusUrl"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSettings"
            android:text="@string/action_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Lists: drafts (local-only, top) + captures (server, below).
         Both are wrapped by a single SwipeRefreshLayout that pulls
         both at once. The empty-state TextView surfaces only when
         BOTH lists are empty. -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/refresh"
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Drafts header + list. Hidden when there are
                         no drafts. -->
                    <TextView
                        android:id="@+id/draftsHeader"
                        android:text="@string/drafts_header"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="4dp"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/drafts"
                        android:nestedScrollingEnabled="false"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Captures header + list. Same hide-when-empty
                         behaviour. -->
                    <TextView
                        android:id="@+id/capturesHeader"
                        android:text="@string/captures_header"
                        android:textColor="@color/muted"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="4dp"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/captures"
                        android:nestedScrollingEnabled="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <TextView
                    android:id="@+id/empty"
                    android:text="@string/empty_no_captures"
                    android:textColor="@color/muted"
                    android:gravity="center"
                    android:padding="32dp"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- New capture: creates a local Draft and hands off to
         CaptureActivity. Stays enabled regardless of studio
         reachability — recording is fully offline. -->
    <Button
        android:id="@+id/btnNewCapture"
        android:text="@string/action_new_capture"
        android:layout_margin="16dp"
        android:padding="16dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/accent"
        android:textColor="@android:color/black"
        android:enabled="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
</LinearLayout>
