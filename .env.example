# ─── Web frontend ─────────────────────────────────────────────────
# Public API base inlined into the Next.js bundle at build time.
# Leave EMPTY (NEXT_PUBLIC_API_BASE=) when running `make up-https` so the
# bundle resolves the api origin from window.location at runtime —
# otherwise the baked-in localhost url mixed-content-blocks from a
# https phone origin. `make up` (plain http) works either way.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ─── Logging ────────────────────────────────────────────────────────
# info | debug | warning
LOG_LEVEL=info

# ─── Capture / training defaults ────────────────────────────────────────
# Used by the api + worker-gs. Override per-session from the web UI.

# Maximum frames to keep from a single capture session before rate-
# limiting / dropping inbound frames. Phone captures at 30 fps will hit
# this in a minute and a half; at that point the server starts dropping
# every Nth frame to stay under the cap.
GS_CAPTURE_MAX_FRAMES=2000

# JPEG quality the phone targets when encoding frames for streaming.
# Bumping this past 85 mostly burns wifi for marginal training gain.
GS_CAPTURE_JPEG_QUALITY=85

# Splatfacto/gsplat training iteration count. 30000 is the upstream
# default; 15000 is fine for room-scale captures and finishes ~2x
# faster on a 4090. Override per-job from the web UI.
GS_TRAIN_ITERS=15000

# ─── SfM ──────────────────────────────────────────────────────────────
# `glomap` (default, fast), `colmap` (fallback, slow but most accurate),
# `none` (mobile capture only — trust the ARCore poses, skip SfM).
GS_SFM_BACKEND=glomap

# ─── Pairing tokens ───────────────────────────────────────────────────
# How long a freshly-minted phone-pair token stays valid for the phone
# to claim it. Once the WS connects + the session goes streaming the
# token is consumed. Default 10 minutes.
GS_PAIR_TOKEN_TTL_SECONDS=600
